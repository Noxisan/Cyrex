# Optional OAuth credentials for one-click "Log in with browser" account connect.
# Copy this file to `.env` (gitignored) and fill in the values you have. Any left
# blank simply fall back to token-paste sign-in for that provider.
#
# These are read at build/dev time (electron.vite.config.ts) and inlined into the
# main process only — never the renderer.

# GitHub: OAuth app client id (device flow, no secret needed).
CYREX_GITHUB_CLIENT_ID=

# GitLab: application id (device flow, no secret needed).
CYREX_GITLAB_CLIENT_ID=

# Bitbucket: OAuth consumer (authorization-code flow, secret required).
# Create under Workspace settings -> OAuth consumers:
#   Callback URL:  http://localhost:47600/callback
#   Permissions:   Account = Read, Repositories = Read + Write
CYREX_BITBUCKET_CLIENT_ID=
CYREX_BITBUCKET_CLIENT_SECRET=
